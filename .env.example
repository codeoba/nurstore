# ============================================================
# Telegram Store Bot — Environment Variables Template
# Nakili faili hii: cp .env.example .env
# Kisha jaza thamani zote hapa chini
# ============================================================

# ─── Bot Configuration ───────────────────────────────────────
# Pata token hii kutoka @BotFather kwenye Telegram
BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghi

# Jina la duka lako (linaonekana kwenye bot)
STORE_NAME=Duka Langu la Digital

# ID ya Channel au Group kwa ajili ya kupost bidhaa na stock mpya (mfano: -100123456789 au @JinaLaChannel)
CHANNEL_ID=

# ─── Admin Settings ──────────────────────────────────────────
# Telegram IDs za wasimamizi wakuu (superadmins)
# Pata ID yako: tuma /start kwa @userinfobot
# Kwa admins wengi, tenganisha kwa koma: 123456789,987654321
ADMIN_IDS=123456789

# ─── Database (PostgreSQL) ───────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Kwa aaPanel: badilisha user, password, na database name
DATABASE_URL=postgresql://storebot_user:strongpassword@localhost:5432/storebot_db

# ─── Redis ───────────────────────────────────────────────────
# Format: redis://HOST:PORT au redis://:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# ─── Telegram Payments ───────────────────────────────────────
# Kwa Telegram Stars: thamani hii si lazima (Stars hazihitaji provider token)
# Kwa malipo ya kadi (Stripe, n.k.): pata token kutoka @BotFather -> /mybots -> Payments
# Acha tupu kama unatumia Stars tu
PAYMENT_PROVIDER_TOKEN=

# ─── File Storage ────────────────────────────────────────────
# Njia kamili ya folda ya uploads kwenye server yako
UPLOAD_DIR=/var/www/telegram-store-bot/uploads

# Kiwango cha juu cha ukubwa wa faili (MB)
MAX_FILE_SIZE_MB=500

# Uhalali wa signed download links (dakika)
SIGNED_URL_EXPIRY_MINUTES=15

# ─── App Settings ────────────────────────────────────────────
NODE_ENV=production

# Kumbukumbu ya kikao (saa)
SESSION_TTL_HOURS=168

# Ukomo wa maombi (requests per minute kwa user)
RATE_LIMIT_RPM=30

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
LOG_DIR=./logs

# ─── Backup ──────────────────────────────────────────────────
# Folda ya kuhifadhi database backups
BACKUP_DIR=/var/backups/telegram-store-bot

# ─── Currency Settings ───────────────────────────────────────
# Kiwango cha ubadilishaji: TZS kwa kila Telegram Star 1
# Stars 1 ≈ $0.013, kwa hiyo: 1 Star ≈ TZS 32 (kubadilisha kulingana na wakati)
TZS_PER_STAR=32

# ─── Referral Settings ───────────────────────────────────────
# Stars za zawadi kwa kila mteja mpya aliyewasilishwa (referral commission)
REFERRAL_COMMISSION_STARS=5

# ─── Job Settings ────────────────────────────────────────────
# Muda wa kutuma ukumbusho wa kikapu kilichoachwa (masaa)
ABANDONED_CART_REMINDER_HOURS=2
